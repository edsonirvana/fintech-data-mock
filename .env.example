# .env.example — copie para .env e preencha com seus valores
# NUNCA commite o arquivo .env

# ─── GCP ────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=paybridge-data-challenge
GCP_REGION=us-central1
GCS_BUCKET=paybridge-data-challenge-raw-zone
GOOGLE_APPLICATION_CREDENTIALS=./infra/keys/dbt-sa-key.json

# ─── PostgreSQL legado (opcional — apenas para modo postgres) ────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DB=paybridge_legacy
PG_USER=readonly_user
PG_PASSWORD=

# ─── Pipeline metadata ───────────────────────────────────────────────────────
TRIGGERED_BY=manual
